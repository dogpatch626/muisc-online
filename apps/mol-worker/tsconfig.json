{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "../../dist/apps/mol-worker",
    "emitDeclarationOnly": false,
    "baseUrl": "../..",
    "paths": {
      "@online-music/types": ["libs/shared/types/src/index.ts"]
    }
  },
  "references": [
    {
      "path": "../../libs/shared/types"
    }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}